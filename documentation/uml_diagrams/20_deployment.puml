@startuml
skinparam backgroundColor #FAFAFA
skinparam node {
  BackgroundColor #EBF5FB
  BorderColor #2196F3
}
skinparam database {
  BackgroundColor #FFF9E6
  BorderColor #E67E22
}
title Diagramme de Deploiement -- FreeNest (Docker, juin 2026)

node "GitHub Actions CI/CD" {
  component "backend.yml
(PHP lint, tests, build)" as CI_B
  component "frontend.yml
(ESLint, Vite, Vitest)" as CI_F
}

node "Docker Host (Production)" {
  node "Container: Frontend" {
    component "React 19 SPA
(Nginx + nginx.conf)" as REACT
    component "Service Worker
(sw.js Push)" as SW
  }
  node "Container: Backend" {
    component "Laravel 12 API
(PHP 8.2-FPM)" as LARAVEL
    component "Laravel Queues
(jobs, emails)" as QUEUE
    component "Laravel Scheduler
(HourlyInvoices)" as SCHED
  }
  node "Container: Soketi" {
    component "WebSocket Server
(Pusher-compatible)" as SOKETI
  }
  node "Container: MySQL 8.0" {
    database "freenest_db
(35+ tables)" as DB
  }
  node "Container: Redis" {
    database "Cache + Sessions
+ Queues" as REDIS
  }
  node "Container: Ollama" {
    component "Mistral 7B
localhost:11434" as OLLAMA
  }
}

cloud "Stripe (SaaS)" {
  component "Stripe Checkout
+ Connect
+ Webhooks" as STRIPE
}
cloud "Google (SaaS)" {
  component "Google OAuth 2.0" as GOOGLE
}

REACT -down-> LARAVEL   : REST API
(Bearer Token)
REACT -down-> SOKETI    : WebSocket
(Socket.IO)
LARAVEL -down-> DB      : SQL / Eloquent
LARAVEL -down-> REDIS   : Cache / Queue
LARAVEL -right-> OLLAMA : HTTP POST
(IA requests)
LARAVEL -up-> STRIPE    : Payments API
LARAVEL -up-> GOOGLE    : OAuth2
STRIPE -down-> LARAVEL  : Webhooks POST
CI_B -down-> LARAVEL    : Deploy on merge
CI_F -down-> REACT      : Deploy on merge
@enduml