  class ContractActivity {
    +id : bigint <<PK>>
    +contract_id : bigint <<FK>>
    +actor_id : bigint <<FK>>
    +type : string
    +data : json
    +created_at : datetime
    ' append-only - no UPDATE/DELETE
  }

  class TimeLog {
    +id : bigint <<PK>>
    +contract_id : bigint <<FK>>
